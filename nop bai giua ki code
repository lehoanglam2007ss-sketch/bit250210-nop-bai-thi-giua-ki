n = int(input("Nhap so luong phan tu N: "))
mang = []

for i in range(n):
    gia_tri = int(input(f"Nhap phan tu thu {i+1}: "))
    mang.append(gia_tri)

print(f"\nMang ban dau: {mang}\n")

for i in range(n - 1):
    vi_tri_max = i
    for j in range(i + 1, n):
        if mang[j] > mang[vi_tri_max]:
            vi_tri_max = j
            
    mang[i], mang[vi_tri_max] = mang[vi_tri_max], mang[i]
    
    print(f"Buoc {i+1}: {mang}")

print(f"\nMang sau khi sap xep giam dan: {mang}")
